# ── Parametric log-normal AFT via MLE ─────────────────────────────────────────
def fit_lognormal_aft(log_time, event, X):
    """
    Log-normal AFT model fitted by maximum likelihood.

    Parameters
    ----------
    log_time : array (n,)  – log of observed time (event or censoring)
    event    : array (n,)  – 1 = event, 0 = right-censored
    X        : array (n,p) – design matrix (include intercept column)

    Returns
    -------
    beta_hat  : array (p,)  – AFT coefficients (log-time scale)
    sigma_hat : float       – estimated scale parameter
    var_beta  : array (p,)  – approximate variances of beta_hat
    """
    n, p = X.shape
    ev = event.astype(bool)

    def neg_ll(params):
        beta  = params[:p]
        sigma = np.exp(params[p])          # log-parameterised → unconstrained
        mu    = X @ beta
        z     = (log_time - mu) / sigma
        ll    = np.where(ev,
                         stats.norm.logpdf(z) - np.log(sigma),
                         stats.norm.logsf(z))
        return -np.nansum(ll)

    # Initialise from OLS on events only
    if ev.sum() > p:
        beta0 = np.linalg.lstsq(X[ev], log_time[ev], rcond=None)[0]
        sig0  = max(np.std(log_time[ev] - X[ev] @ beta0), 0.05)
    else:
        beta0, sig0 = np.zeros(p), 1.0

    x0  = np.append(beta0, np.log(sig0))
    res = _minimize(neg_ll, x0, method="BFGS",
                    options={"maxiter": 3000, "gtol": 1e-6})

    beta_hat  = res.x[:p]
    sigma_hat = np.exp(res.x[p])

    # Variance from BFGS inverse-Hessian approximation
    try:
        var_all  = np.diag(np.array(res.hess_inv))
        var_beta = var_all[:p]
    except Exception:
        var_beta = np.full(p, np.nan)

    return beta_hat, sigma_hat, var_beta


# ── Helper: OLS fit (for mediator models) ────────────────────────────────────
def _fit_ols(formula, data):
    try:
        vars_needed = [s.strip() for s in formula.replace("~", "+").split("+")]
        return smf.ols(formula, data=data.dropna(subset=vars_needed)).fit()
    except Exception:
        return None


# ── Main SNAFT function ───────────────────────────────────────────────────────
def run_snaft_sex(sex_label, imp_datasets_list):
    """
    Sequential SNAFT g-estimation for one sex stratum.

    For each imputed dataset:
      1. Merges outcome variables (event, time) from original df.
      2. Fits log-normal AFT models backwards (C → B → A) to estimate ψ.
      3. Runs Monte-Carlo scenario simulation (+1 / −1 SD per velocity),
         propagating interventions through mediator-model predictions.
      4. Reports pooled Time Ratios (TR = exp(ψ·SD)) via Rubin's rules.
    """
    sex_val = 1 if sex_label == "Boys" else 0

    # Outcome variable names (sex-specific)
    age_col = "G_age" if sex_val == 1 else "M_age"

    # Storage: {exposure: list of (psi_hat, var_psi, SD_exp)}
    psi_store = {e: [] for e in ALL_EXPS}

    # Storage for covariate fixed effects from full AFT model (Step 1)
    # {covariate: list of (beta_hat, var_beta)}
    cov_store = {}

    # Scenario-level storage for Monte-Carlo TR (pooled across imputations)
    scenarios = {
        f"{e}_+1SD": (e, +1) for e in ALL_EXPS
    }
    scenarios.update({
        f"{e}_-1SD": (e, -1) for e in ALL_EXPS
    })
    mc_store = {sc: [] for sc in scenarios}

    for _, data_k in enumerate(imp_datasets_list):
        dk = data_k.copy()

        # ── Merge outcome variables from original (non-imputed) data ──────
        for col in ["event", "time", "_last_wt_age", age_col]:
            if col in df.columns:
                dk[col] = df.loc[dk.index, col]

        # Subset to sex; require both outcome and at least one velocity
        dk = dk[dk["boy"] == sex_val].copy()
        dk = dk.dropna(subset=["event", "time"])
        if len(dk) < 30:
            continue

        # Recalculate velocities on this imputed dataset
        dk[EXP_A_WT] = dk["b_wt"]  - dk["birth_wt"]
        dk[EXP_A_HT] = dk["b_ht"]  - dk["birth_ht"]
        dk[EXP_B_WT] = dk["b2_wt"] - dk["b_wt"]
        dk[EXP_B_HT] = dk["b2_ht"] - dk["b_ht"]
        dk[EXP_C_WT] = dk["b5_wt"] - dk["b2_wt"]
        dk[EXP_C_HT] = dk["b5_ht"] - dk["b2_ht"]

        exp_sds = {e: dk[e].std() for e in ALL_EXPS}

        # Drop rows with non-positive time (log undefined)
        dk = dk[dk["time"] > 0].copy()
        log_time = np.log(dk["time"].values)
        event_k  = dk["event"].values.astype(float)

        cov_cols = [c for c in BASE_COVARIATES
                    if c in dk.columns and dk[c].nunique() > 1]

        def _design(data, cols):
            """Build design matrix with intercept."""
            X = data[cols].copy()
            X.insert(0, "_intercept", 1.0)
            return X.fillna(X.mean()).values

        # ── Step 1: AFT for period C velocities ──────────────────────────
        # Full model: log T ~ vel_C + vel_B + vel_A + covariates
        full_cols = ALL_EXPS + cov_cols
        full_cols = [c for c in full_cols if c in dk.columns]
        X_full = _design(dk, full_cols)
        try:
            beta_full, _, var_full = fit_lognormal_aft(log_time, event_k, X_full)
        except Exception:
            continue

        # Map column names to beta indices (0 = intercept)
        col_idx = {c: i + 1 for i, c in enumerate(full_cols)}

        def _psi_var(exp_name):
            idx = col_idx.get(exp_name)
            if idx is None:
                return np.nan, np.nan
            return beta_full[idx], var_full[idx]

        psi_C_wt, var_C_wt = _psi_var(EXP_C_WT)
        psi_C_ht, var_C_ht = _psi_var(EXP_C_HT)
        psi_store[EXP_C_WT].append((psi_C_wt, var_C_wt, exp_sds[EXP_C_WT]))
        psi_store[EXP_C_HT].append((psi_C_ht, var_C_ht, exp_sds[EXP_C_HT]))

        # ── Extract covariate betas from full model ───────────────────────
        for cov in cov_cols:
            idx = col_idx.get(cov)
            if idx is None:
                continue
            if cov not in cov_store:
                cov_store[cov] = []
            cov_store[cov].append((beta_full[idx], var_full[idx]))

        # ── Step 2: Counterfactual U_B = time · exp(−ψ_C · vel_C) ───────
        U_B = dk["time"].values * np.exp(
            -psi_C_wt * dk[EXP_C_WT].values
            -psi_C_ht * dk[EXP_C_HT].values
        )
        U_B = np.clip(U_B, 1e-6, None)
        log_U_B = np.log(U_B)

        # ── Step 3: AFT for period B velocities on U_B ───────────────────
        B_cols = [EXP_B_WT, EXP_B_HT, EXP_A_WT, EXP_A_HT] + cov_cols
        B_cols = [c for c in B_cols if c in dk.columns]
        X_B = _design(dk, B_cols)
        try:
            beta_B, _, var_B = fit_lognormal_aft(log_U_B, event_k, X_B)
        except Exception:
            continue

        col_idx_B = {c: i + 1 for i, c in enumerate(B_cols)}
        def _psi_var_B(exp_name):
            idx = col_idx_B.get(exp_name)
            if idx is None:
                return np.nan, np.nan
            return beta_B[idx], var_B[idx]

        psi_B_wt, var_B_wt = _psi_var_B(EXP_B_WT)
        psi_B_ht, var_B_ht = _psi_var_B(EXP_B_HT)
        psi_store[EXP_B_WT].append((psi_B_wt, var_B_wt, exp_sds[EXP_B_WT]))
        psi_store[EXP_B_HT].append((psi_B_ht, var_B_ht, exp_sds[EXP_B_HT]))

        # ── Step 4: Counterfactual U_A = U_B · exp(−ψ_B · vel_B) ────────
        U_A = U_B * np.exp(
            -psi_B_wt * dk[EXP_B_WT].values
            -psi_B_ht * dk[EXP_B_HT].values
        )
        U_A = np.clip(U_A, 1e-6, None)
        log_U_A = np.log(U_A)

        # ── Step 5: AFT for period A velocities on U_A ───────────────────
        A_cols = [EXP_A_WT, EXP_A_HT] + cov_cols
        A_cols = [c for c in A_cols if c in dk.columns]
        X_A = _design(dk, A_cols)
        try:
            beta_A, _, var_A = fit_lognormal_aft(log_U_A, event_k, X_A)
        except Exception:
            continue

        col_idx_A = {c: i + 1 for i, c in enumerate(A_cols)}
        def _psi_var_A(exp_name):
            idx = col_idx_A.get(exp_name)
            if idx is None:
                return np.nan, np.nan
            return beta_A[idx], var_A[idx]

        psi_A_wt, var_A_wt = _psi_var_A(EXP_A_WT)
        psi_A_ht, var_A_ht = _psi_var_A(EXP_A_HT)
        psi_store[EXP_A_WT].append((psi_A_wt, var_A_wt, exp_sds[EXP_A_WT]))
        psi_store[EXP_A_HT].append((psi_A_ht, var_A_ht, exp_sds[EXP_A_HT]))

        # ── Mediator models (OLS) for Monte-Carlo scenario propagation ────
        cov_str = " + ".join(cov_cols) if cov_cols else ""
        def _cov(suffix=""):
            return (f" + {cov_str}" if cov_str else "")

        m_bwt = _fit_ols(f"{EXP_B_WT} ~ {EXP_A_WT} + {EXP_A_HT}" + _cov(), dk)
        m_bht = _fit_ols(f"{EXP_B_HT} ~ {EXP_A_WT} + {EXP_A_HT}" + _cov(), dk)
        m_cwt = _fit_ols(
            f"{EXP_C_WT} ~ {EXP_A_WT} + {EXP_A_HT} + {EXP_B_WT} + {EXP_B_HT}" + _cov(), dk)
        m_cht = _fit_ols(
            f"{EXP_C_HT} ~ {EXP_A_WT} + {EXP_A_HT} + {EXP_B_WT} + {EXP_B_HT}" + _cov(), dk)

        if any(m is None for m in [m_bwt, m_bht, m_cwt, m_cht]):
            continue

        # Collect per-scenario log-TR using current imputation's ψ estimates
        psi_map = {
            EXP_A_WT: psi_A_wt, EXP_A_HT: psi_A_ht,
            EXP_B_WT: psi_B_wt, EXP_B_HT: psi_B_ht,
            EXP_C_WT: psi_C_wt, EXP_C_HT: psi_C_ht,
        }

        for sc_name, (target_exp, direction) in scenarios.items():
            sim = dk.copy()
            shift = direction * exp_sds[target_exp]
            sim[target_exp] = sim[target_exp] + shift

            # Propagate through mediator chain if target is upstream
            if target_exp in [EXP_A_WT, EXP_A_HT]:
                sim[EXP_B_WT] = m_bwt.predict(sim)
                sim[EXP_B_HT] = m_bht.predict(sim)
                sim[EXP_C_WT] = m_cwt.predict(sim)
                sim[EXP_C_HT] = m_cht.predict(sim)
            elif target_exp in [EXP_B_WT, EXP_B_HT]:
                sim[EXP_C_WT] = m_cwt.predict(sim)
                sim[EXP_C_HT] = m_cht.predict(sim)

            # Log-TR = Σ ψ_k · Δvel_k  (linear in log-time)
            log_tr = sum(
                psi_map[e] * (sim[e].values - dk[e].values)
                for e in ALL_EXPS if e in sim.columns and e in dk.columns
            )
            mc_store[sc_name].append(log_tr.mean())

    # ── Pool ψ estimates via Rubin's rules ────────────────────────────────────
    def _rubins(vals_vars_sds):
        """Pool list of (psi, var_psi, sd_exp) tuples. Works for m=1 (no imputation)."""
        if not vals_vars_sds:
            return {}
        psis  = np.array([v[0] for v in vals_vars_sds])
        vars_ = np.array([v[1] for v in vals_vars_sds])
        sds   = np.array([v[2] for v in vals_vars_sds])
        m     = len(psis)
        psi_bar = psis.mean()
        sd_bar  = sds.mean()
        U_bar   = np.nanmean(vars_)
        B       = np.var(psis, ddof=1) if m > 1 else 0.0
        T       = U_bar + (1 + 1/m) * B
        SE      = np.sqrt(max(T, 0))
        r       = (1 + 1/m) * B / U_bar if (U_bar > 0 and m > 1) else 0.0
        df_br   = (m - 1) * (1 + 1/r) ** 2 if (m > 1 and r > 0 and np.isfinite(r)) else 999
        t_val   = psi_bar / SE if SE > 0 else np.nan
        p_val   = 2 * stats.t.sf(abs(t_val), df=df_br) if not np.isnan(t_val) else np.nan
        tr_1sd  = np.exp(psi_bar * sd_bar)
        ci_lo   = np.exp((psi_bar - 1.96 * SE) * sd_bar)
        ci_hi   = np.exp((psi_bar + 1.96 * SE) * sd_bar)
        return dict(
            psi=round(psi_bar, 5), SE_psi=round(SE, 5),
            TR_1SD=round(tr_1sd, 4),
            CI_low=round(ci_lo, 4), CI_high=round(ci_hi, 4),
            P_value=f"{p_val:.4e}" if not np.isnan(p_val) else "NA",
            Sig=("***" if (not np.isnan(p_val) and p_val < 0.001)
                 else ("**" if (not np.isnan(p_val) and p_val < 0.01)
                       else ("*" if (not np.isnan(p_val) and p_val < 0.05) else ""))),
            N_imp=m,
        )

    period_map = {
        EXP_A_WT: "Early infancy",  EXP_A_HT: "Early infancy",
        EXP_B_WT: "Late infancy",   EXP_B_HT: "Late infancy",
        EXP_C_WT: "Early childhood",EXP_C_HT: "Early childhood",
    }
    meas_map = {e: ("Weight" if "wt" in e else "Height") for e in ALL_EXPS}

    rows = []
    for exp in ALL_EXPS:
        d = _rubins(psi_store[exp])
        if not d:
            continue
        rows.append({
            "Sex": sex_label,
            "Exposure": exp,
            "Period": period_map[exp],
            "Measurement": meas_map[exp],
            **d,
            "Interpretation": (
                "TR<1 → earlier puberty" if d["TR_1SD"] < 1
                else "TR>1 → later puberty"
            ),
        })

    # ── Pool covariate fixed effects via Rubin's rules ────────────────────
    def _rubins_cov(vals_vars):
        """Pool list of (beta, var_beta) tuples (no SD scaling — raw log-time scale)."""
        if not vals_vars:
            return {}
        betas = np.array([v[0] for v in vals_vars])
        vars_ = np.array([v[1] for v in vals_vars])
        m       = len(betas)
        b_bar   = betas.mean()
        U_bar   = np.nanmean(vars_)
        B       = np.var(betas, ddof=1) if m > 1 else 0.0
        T       = U_bar + (1 + 1/m) * B
        SE      = np.sqrt(max(T, 0))
        r       = (1 + 1/m) * B / U_bar if (U_bar > 0 and m > 1) else 0.0
        df_br   = (m - 1) * (1 + 1/r) ** 2 if (m > 1 and r > 0 and np.isfinite(r)) else 999
        t_val   = b_bar / SE if SE > 0 else np.nan
        p_val   = 2 * stats.t.sf(abs(t_val), df=df_br) if not np.isnan(t_val) else np.nan
        return dict(
            Beta=round(b_bar, 5), SE=round(SE, 5),
            CI_low=round(b_bar - 1.96 * SE, 5),
            CI_high=round(b_bar + 1.96 * SE, 5),
            P_value=f"{p_val:.4e}" if not np.isnan(p_val) else "NA",
            Sig=("***" if (not np.isnan(p_val) and p_val < 0.001)
                 else ("**" if (not np.isnan(p_val) and p_val < 0.01)
                       else ("*" if (not np.isnan(p_val) and p_val < 0.05) else ""))),
            N_imp=m,
        )

    cov_rows = []
    for cov, vals in cov_store.items():
        d = _rubins_cov(vals)
        if not d:
            continue
        cov_rows.append({"Sex": sex_label, "Covariate": cov, **d})

    return pd.DataFrame(rows), mc_store, pd.DataFrame(cov_rows)


