def describe_one(data: pd.DataFrame, varname: str, vtype: str) -> dict:
    """Return a dict of summary stats for one variable in 'data'."""
    col = data[varname]
    n_total   = len(col)
    n_missing = col.isna().sum()
    n_valid   = n_total - n_missing
    pct_miss  = 100.0 * n_missing / n_total if n_total > 0 else np.nan

    if vtype == "cont":
        return {
            "N_total":    n_total,
            "N_valid":    n_valid,
            "N_missing":  n_missing,
            "Pct_missing": round(pct_miss, 1),
            "Mean":       round(col.mean(), 3),
            "SD":         round(col.std(),  3),
            "Median":     round(col.median(), 3),
            "Q1":         round(col.quantile(0.25), 3),
            "Q3":         round(col.quantile(0.75), 3),
            "Min":        round(col.min(), 3),
            "Max":        round(col.max(), 3),
        }
    else:          # categorical
        vc = col.value_counts(dropna=True)
        freq_str = "; ".join(
            [f"{k}: {v} ({100*v/n_valid:.1f}%)"
             for k, v in vc.items()]
        ) if n_valid > 0 else "—"
        return {
            "N_total":    n_total,
            "N_valid":    n_valid,
            "N_missing":  n_missing,
            "Pct_missing": round(pct_miss, 1),
            "Frequencies": freq_str,
        }


def build_desc_table(data: pd.DataFrame,
                     cont_vars, cat_vars,
                     label: str = "") -> pd.DataFrame:
    """Build a single descriptive table for *data*."""
    rows = []
    for vname, vlabel in cont_vars:
        if vname not in data.columns:
            continue
        d = describe_one(data, vname, "cont")
        rows.append({
            "Variable":   vname,
            "Label":      vlabel,
            "Type":       "Continuous",
            **d,
        })
    for vname, vlabel in cat_vars:
        if vname not in data.columns:
            continue
        d = describe_one(data, vname, "cat")
        rows.append({
            "Variable":   vname,
            "Label":      vlabel,
            "Type":       "Categorical",
            **d,
        })
    tbl = pd.DataFrame(rows)
    tbl.insert(0, "Cohort", label)
    return tbl


