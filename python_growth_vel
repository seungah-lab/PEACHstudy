def pairwise_table(data, varlist, label):
    """Compute Pearson r (+ p-value) for all pairs; return long-format df."""
    rows = []
    for i, v1 in enumerate(varlist):
        for j, v2 in enumerate(varlist):
            if j <= i:
                continue
            sub = data[[v1, v2]].dropna()
            if len(sub) < 10:
                continue
            r, p = stats.pearsonr(sub[v1], sub[v2])
            rows.append({
                "Group":    label,
                "Var1":     v1,
                "Var2":     v2,
                "N":        len(sub),
                "Pearson_r": round(r, 4),
                "P_value":  f"{p:.4e}",
                "Sig":      "***" if p < 0.001 else ("**" if p < 0.01 else ("*" if p < 0.05 else "")),
            })
    return pd.DataFrame(rows)

