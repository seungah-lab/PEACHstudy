# =============================================================================
# Table 1. DESCRIPTIVE TABLES
# =============================================================================

get_summary <- function(data, label) {
  # --- Continuous Variables ---
  cont_vars_present <- intersect(names(data), CONT_VARS)
  
  cont_summ <- data %>%
    select(all_of(cont_vars_present)) %>%
    summarise(across(everything(), list(
      Mean = ~mean(., na.rm=T), 
      SD = ~sd(., na.rm=T), 
      Median = ~median(., na.rm=T), 
      Missing = ~sum(is.na(.)),
      PctMiss = ~round(100 * sum(is.na(.)) / n(), 1)
    ))) %>%
    # Use names_pattern to capture everything BEFORE the last underscore as the variable name
    # and everything AFTER the last underscore as the statistic.
    pivot_longer(everything(), 
                 names_to = c("Variable", ".value"), 
                 names_pattern = "(.*)_(Mean|SD|Median|Missing|PctMiss)")
  
  # --- Categorical Variables ---
  cat_vars_present <- intersect(names(data), CAT_VARS)
  
  cat_summ_list <- lapply(cat_vars_present, function(v) {
    n_total <- nrow(data)
    n_miss <- sum(is.na(data[[v]]))
    n_valid <- n_total - n_miss
    pct_miss <- round(100 * n_miss / n_total, 1)
    
    # Calculate frequencies for valid (non-missing) data
    freqs <- data %>%
      filter(!is.na(!!sym(v))) %>%
      group_by(!!sym(v)) %>%
      summarise(n = n(), .groups = 'drop') %>%
      mutate(pct = round(100 * n / n_valid, 1),
             entry = paste0(!!sym(v), ": ", n, " (", pct, "%)")) %>%
      summarise(Frequencies = paste(entry, collapse = "; "))
    
    data.frame(
      Variable = v,
      Mean = NA, SD = NA, Median = NA, # Placeholders to match continuous table
      Missing = n_miss,
      PctMiss = pct_miss,
      Frequencies = freqs$Frequencies
    )
  })
  
  cat_summ <- bind_rows(cat_summ_list)
  
  # --- Combine Both ---
  bind_rows(
    cont_summ %>% mutate(Type = "Continuous"),
    cat_summ %>% mutate(Type = "Categorical")
  ) %>% 
    mutate(Cohort = label) %>%
    select(Cohort, Variable, Type, Mean, SD, Median, Missing, PctMiss, Frequencies)
}

tbl_all   <- get_summary(df_pooled, "Combined")

# Final combined descriptive table
write_csv(tbl_all, file.path(OUTPUT_DIR, "1_descriptive_table_with_R.csv"))

