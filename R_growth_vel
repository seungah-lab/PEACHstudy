# Define Variable Groups
CONT_VARS <- c("ga", "m_age", "m_ht", "m_pre1_wt", "m_pre2_wt", "m_diff_wt", 
               "birth_wt", "birth_ht", "ponderal_index", "b_wt", "b_ht", 
               "b1_wt", "b1_ht", "b2_wt", "b2_ht", "b5_wt", "b5_ht", "puberty_age")

CAT_VARS <- c("boy", "cs", "first_order", "m_univ", "f_univ", "m_employed", 
              "f_employed", "m_smoking_preg", "f_smoking", "event","b3_rural")

BASE_COVARIATES <- c("ga", "m_age", "birth_wt", "birth_ht", "ponderal_index", "m_diff_wt",
                     "cs", "first_order", "m_univ", "f_univ", "m_employed", "f_employed",
                     "m_smoking_preg", "f_smoking", "b3_rural")

VEL_VARS <- c("vel_wt_early_inf", "vel_ht_early_inf", "vel_wt_late_inf", 
