plot_corr <- function(data, title, filename) {
  cor_mat <- cor(data %>% select(all_of(intersect(names(.), CONT_VARS))), use = "pairwise.complete.obs")
  png(file.path(OUTPUT_DIR, filename), width = 800, height = 800)
  corrplot(cor_mat, method = "color", type = "upper", title = title, 
           mar=c(0,0,1,0), tl.col="black", tl.srt=45, addCoef.col = "black", number.cex = 0.7)
  dev.off()
}

