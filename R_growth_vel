# 1. Create a function to extract covariate effects from Step 1 of SNAFT
get_covariate_effects <- function(data, sex_label) {
  # Subset and clean data
  sub_df <- data %>% 
    filter(boy == ifelse(sex_label == "Boys", 1, 0)) %>% 
    drop_na(time, event, all_of(VEL_VARS), all_of(BASE_COVARIATES))
  
  # Step 1 Model (Full model including all exposures and covariates)
  formula_full <- as.formula(paste("Surv(time, event) ~", 
                                   paste(c(VEL_VARS, BASE_COVARIATES), collapse = " + ")))
  fit_full <- survreg(formula_full, data = sub_df, dist = "lognormal")
  
  # Extract results using broom::tidy
  model_results <- tidy(fit_full, conf.int = TRUE) %>%
    filter(term %in% BASE_COVARIATES) %>% # Keep only the baseline covariates
    mutate(
      Sex = sex_label,
      # In AFT, exp(Beta) is the Time Ratio
      TR = exp(estimate),
      TR_CI_low = exp(conf.low),
      TR_CI_high = exp(conf.high),
      P_value = p.value,
      Sig = case_when(
        P_value < 0.001 ~ "***",
        P_value < 0.01 ~ "**",
        P_value < 0.05 ~ "*",
        TRUE ~ ""
      ),
      Interpretation = ifelse(TR < 1, "Earlier Puberty", "Later Puberty")
    ) %>%
    select(Sex, Covariate = term, Beta = estimate, SE = std.error, 
           TR, TR_CI_low, TR_CI_high, P_value, Sig, Interpretation)
  
  return(model_results)
}

cov_effects_boys  <- get_covariate_effects(df_pooled, "Boys")
cov_effects_girls <- get_covariate_effects(df_pooled, "Girls")
final_cov_table   <- bind_rows(cov_effects_boys, cov_effects_girls)

cov_output_path <- file.path(OUTPUT_DIR, "4c_covariate_fixed_effects.csv")
write_csv(final_cov_table, cov_output_path)

