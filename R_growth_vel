# =============================================================================
# Table 2. G-estimation of structural nested accelerated failure-time (SNAFT) model
# =============================================================================

run_snaft <- function(data, sex_label) {
  # Subset by sex
  sub_df <- data %>% 
    filter(boy == ifelse(sex_label == "Boys", 1, 0)) %>% 
    drop_na(time, event, all_of(VEL_VARS), all_of(BASE_COVARIATES))
  
  if(nrow(sub_df) < 50) return(NULL)
  
  # Calculate SDs for 1-SD Time Ratio interpretation
  sds <- sub_df %>% summarise(across(all_of(VEL_VARS), sd))
  
  # --- Step 1: Period C (Early Childhood) ---
  # Model: log(T) ~ Vel_C + Vel_B + Vel_A + Covariates
  formula_c <- as.formula(paste("Surv(time, event) ~", 
                                paste(c(VEL_VARS, BASE_COVARIATES), collapse = " + ")))
  fit_c <- survreg(formula_c, data = sub_df, dist = "lognormal")
  
  psi_c_wt <- coef(fit_c)["vel_wt_early_ch"]
  psi_c_ht <- coef(fit_c)["vel_ht_early_ch"]
  
  # --- Step 2: Compute Counterfactual U_B ---
  # U_B represents the puberty time if childhood growth had been zero
  sub_df$U_B <- sub_df$time * exp(-(psi_c_wt * sub_df$vel_wt_early_ch + 
                                      psi_c_ht * sub_df$vel_ht_early_ch))
  
  # --- Step 3: Period B (Late Infancy) ---
  # Model: log(U_B) ~ Vel_B + Vel_A + Covariates
  formula_b <- as.formula(paste("Surv(U_B, event) ~", 
                                paste(c(VEL_VARS[1:4], BASE_COVARIATES), collapse = " + ")))
  fit_b <- survreg(formula_b, data = sub_df, dist = "lognormal")
  
  psi_b_wt <- coef(fit_b)["vel_wt_late_inf"]
  psi_b_ht <- coef(fit_b)["vel_ht_late_inf"]
  
  # --- Step 4: Compute Counterfactual U_A ---
  sub_df$U_A <- sub_df$U_B * exp(-(psi_b_wt * sub_df$vel_wt_late_inf + 
                                     psi_b_ht * sub_df$vel_ht_late_inf))
  
  # --- Step 5: Period A (Early Infancy) ---
  formula_a <- as.formula(paste("Surv(U_A, event) ~", 
                                paste(c(VEL_VARS[1:2], BASE_COVARIATES), collapse = " + ")))
  fit_a <- survreg(formula_a, data = sub_df, dist = "lognormal")
  
  # --- Collect and Format Results ---
  res_list <- list(
    tidy(fit_a) %>% filter(term %in% VEL_VARS[1:2]),
    tidy(fit_b) %>% filter(term %in% VEL_VARS[3:4]),
    tidy(fit_c) %>% filter(term %in% VEL_VARS[5:6])
  )
  
  results <- bind_rows(res_list) %>%
    mutate(
      Sex = sex_label,
      # TR_1SD (Time Ratio (TR) n): relative change in puberty age for a +1 Standard Deviation increase in velocity
      SD_val = as.numeric(sds[term]),
      TR_1SD = exp(estimate * SD_val),
      CI_low = exp((estimate - 1.96 * std.error) * SD_val),
      CI_high = exp((estimate + 1.96 * std.error) * SD_val),
      P_value = p.value,
      Sig = case_when(
        P_value < 0.001 ~ "***",
        P_value < 0.01 ~ "**",
        P_value < 0.05 ~ "*",
        TRUE ~ ""
      )
    ) %>%
    select(Sex, Exposure = term, Beta = estimate, TR_1SD, CI_low, CI_high, P_value, Sig)
  
  return(results)
}

